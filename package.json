    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/great-vibes": "^5.2.8",
    "@fontsource/lato": "^5.2.7",
    "@lucide/astro": "^1.21.0",
    "@sanity/astro": "^3.4.1",
    "@sanity/client": "^7.23.0",
    "@sanity/image-url": "^2.1.1",
    "astro": "^6.4.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "groq": "^6.1.0",
    "tailwind-merge": "^3.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
