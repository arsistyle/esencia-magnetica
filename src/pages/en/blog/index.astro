---
// src/pages/en/blog/index.astro
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogFilters from "@/components/blog/BlogFilters.astro";
import FeaturedPost from "@/components/blog/FeaturedPost.astro";
import PostGrid from "@/components/blog/PostGrid.astro";
import BlogPagination from "@/components/blog/BlogPagination.astro";
import { sanityClient } from "sanity:client";
import {
  postsFilteredQuery,
  postsCountQuery,
  blogCategoriesQuery,
} from "@/lib/queries";
import { POSTS_PER_PAGE } from "@/lib/constants";
import { useTranslations } from "@/i18n";
import Badge from "@/components/ui/Badge.astro";
import type { Locale } from "@/types/index";

interface PostItem {
  _id: string;
  title: string;
  slug: { current: string };
  excerpt?: string;
  publishedAt: string;
  featured?: boolean;
  coverImage?: unknown;
  readTime?: number;
  category?: { name: Record<string, string>; slug: { current: string } };
}

const lang: Locale = "en";
const t = useTranslations(lang);

const categoria = Astro.url.searchParams.get("categoria") ?? "";
const q = Astro.url.searchParams.get("q") ?? "";
const page = Math.max(1, Number(Astro.url.searchParams.get("page") ?? "1"));
const offset = (page - 1) * POSTS_PER_PAGE;
const end = offset + POSTS_PER_PAGE;

const [rawPosts, total, categories] = await Promise.all([
  sanityClient.fetch(postsFilteredQuery, { lang, categoria, q, offset, end }),
  sanityClient.fetch(postsCountQuery, { lang, categoria, q }),
  sanityClient.fetch(blogCategoriesQuery),
]);

const posts = rawPosts as PostItem[];
const totalPages = Math.ceil((total ?? 0) / POSTS_PER_PAGE);

const featured =
  !categoria && !q && page === 1
    ? (posts.find((p) => p.featured) ?? null)
    : null;
const gridPosts = featured
  ? posts.filter((p) => p._id !== featured._id)
  : posts;
---

<BaseLayout
  title={t("nav.blog")}
  description={t("blog.description")}
  lang={lang}
>
  <div
    class="mx-auto max-w-[var(--container)] [padding:var(--space-9)_var(--gutter)]"
  >
    <div class="mb-10 text-center">
      <Badge tone="gold" class="mb-4">{t("nav.blog")}</Badge>
      <h1
        class="text-h1 text-olive mb-4 font-serif leading-tight font-semibold"
      >
        {t("blog.headline")}
      </h1>
      <p class="text-lead text-olive-soft mx-auto max-w-[640px]">
        {t("blog.lead")}
      </p>
    </div>
    <BlogFilters
      categories={categories}
      activeCategoria={categoria}
      activeQ={q}
      lang={lang}
    />
    <div class="mt-10 flex flex-col gap-12">
      {featured && <FeaturedPost post={featured} lang={lang} />}
      <PostGrid posts={gridPosts} q={q} lang={lang} />
      <BlogPagination
        currentPage={page}
        totalPages={totalPages}
        currentUrl={Astro.url.toString()}
        lang={lang}
      />
    </div>
  </div>
</BaseLayout>
