---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Button from "@/components/ui/Button.astro";
import Badge from "@/components/ui/Badge.astro";
import Card from "@/components/ui/Card.astro";
import Input from "@/components/ui/Input.astro";
---

<BaseLayout title="Smoke test">
  <div class="space-y-8 p-8">
    <section>
      <h2 class="mb-4 text-lg font-bold">Buttons</h2>
      <div class="flex flex-wrap items-center gap-4">
        <Button>Primary</Button>
        <Button variant="secondary">Secondary</Button>
        <Button variant="ghost">Ghost</Button>
        <Button variant="warm">Warm</Button>
        <Button size="sm">Small</Button>
        <Button size="lg">Large</Button>
        <Button href="#" variant="secondary">Link Button</Button>
        <Button disabled>Disabled</Button>
        <Button class="w-full">Full width override</Button>
      </div>
    </section>

    <section>
      <h2 class="mb-4 text-lg font-bold">Badges</h2>
      <div class="flex flex-wrap items-center gap-4">
        <Badge>Gold (default)</Badge>
        <Badge tone="olive">Olive</Badge>
        <Badge tone="lavender">Lavender</Badge>
        <Badge tone="rose">Rose</Badge>
        <Badge tone="neutral">Neutral</Badge>
        <Badge size="sm">Small Gold</Badge>
        <Badge tone="olive" size="sm">Small Olive</Badge>
      </div>
    </section>

    <section>
      <h2 class="mb-4 text-lg font-bold">Cards</h2>
      <div class="grid gap-6 md:grid-cols-2">
        <Card>
          <h3 class="mb-2 text-lg font-bold">Default Card</h3>
          <p class="text-body">
            Standard card with hover lift and medium padding.
          </p>
        </Card>
        <Card hover={false}>
          <h3 class="mb-2 text-lg font-bold">No Hover</h3>
          <p class="text-body">This card has no hover effect.</p>
        </Card>
        <Card padding="sm">
          <h3 class="mb-2 text-lg font-bold">Small Padding</h3>
          <p class="text-body">Card with reduced padding.</p>
        </Card>
        <Card padding="lg" hover={true}>
          <h3 class="mb-2 text-lg font-bold">Large Padding</h3>
          <p class="text-body">Card with generous padding and hover lift.</p>
        </Card>
      </div>
    </section>

    <section>
      <h2 class="mb-4 text-lg font-bold">Inputs</h2>
      <div class="max-w-md space-y-6">
        <Input
          label="Email"
          type="email"
          placeholder="you@example.com"
          required
        />
        <Input
          label="Full Name"
          type="text"
          placeholder="Enter your full name"
          hint="We'll use this for personalized content"
        />
        <Input label="Search" type="text" placeholder="Search articles..." />
        <Input
          label="Message"
          type="text"
          placeholder="Your message here"
          hint="Required field"
          required
        />
      </div>
    </section>
  </div>
</BaseLayout>
