---
// src/components/blog/FeaturedPost.astro
import type { Locale } from "@/types/index";
import { useTranslations } from "@/i18n";
import { urlFor } from "@/lib/sanity";
import Badge from "@/components/ui/Badge.astro";
import { formatPostDate } from "@/lib/blog/postViewModel";

interface Props {
  post: {
    _id: string;
    title: string;
    slug: { current: string };
    excerpt?: string;
    publishedAt: string;
    coverImage?: unknown;
    readTime?: number;
    category?: { name: Record<string, string>; slug: { current: string } };
  };
  lang: Locale;
}

const { post, lang } = Astro.props;
const t = useTranslations(lang);
const href =
  lang === "es"
    ? `/blog/${post.slug.current}`
    : `/en/blog/${post.slug.current}`;
const imgSrc = post.coverImage
  ? urlFor(post.coverImage as Parameters<typeof urlFor>[0])
      .width(1200)
      .height(800)
      .url()
  : null;
const date = formatPostDate(post.publishedAt, lang);
const mins = Math.max(1, post.readTime ?? 1);
const categoryName =
  (post.category?.name as Record<string, string> | undefined)?.[lang] ??
  (post.category?.name as Record<string, string> | undefined)?.es ??
  "";
---

<a
  href={href}
  class="group rounded-radius-lg border-line bg-cream-card grid grid-cols-1 overflow-hidden border shadow-sm transition-all duration-300 hover:shadow-md lg:grid-cols-[1.5fr_1fr]"
>
  <div class="overflow-hidden">
    {
      imgSrc ? (
        <img
          src={imgSrc}
          alt={post.title}
          loading="eager"
          class="h-64 w-full object-cover transition-transform duration-500 group-hover:scale-[1.02] lg:h-full lg:min-h-80"
        />
      ) : (
        <div class="bg-lavender h-64 w-full lg:h-full lg:min-h-80" />
      )
    }
  </div>
  <div class="flex flex-col justify-center gap-4 p-8">
    <div class="flex flex-wrap items-center gap-3">
      <Badge tone="rose">{t("blog.featured")}</Badge>
      {
        categoryName && (
          <span class="text-overline text-gold font-sans font-bold tracking-wider uppercase">
            {categoryName}
          </span>
        )
      }
    </div>
    <h2
      class="text-h2 text-olive font-serif leading-tight font-semibold"
      style="font-size: clamp(1.6rem, 3vw, 2.4rem);"
    >
      {post.title}
    </h2>
    {
      post.excerpt && (
        <p class="text-small text-olive-soft lg:text-body leading-normal">
          {post.excerpt}
        </p>
      )
    }
    <p class="text-caption text-olive-faint">
      {date} · {mins}
      {t("blog.minutes")}
    </p>
  </div>
</a>
