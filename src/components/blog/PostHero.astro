---
// src/components/blog/PostHero.astro
import type { Locale } from "@/types/index";
import { useTranslations } from "@/i18n";
import { resolveImageUrl, type CoverImageLike } from "@/lib/sanity";
import Badge from "@/components/ui/Badge.astro";
import { formatPostDate, readingTime } from "@/lib/blog/postViewModel";

interface Props {
  post: {
    title: string;
    publishedAt: string;
    excerpt?: string;
    coverImage?: unknown;
    category?: { name: Record<string, string> };
    authors?: Array<{ name: string }>;
    body?: unknown[];
  };
  lang: Locale;
}

const { post, lang } = Astro.props;
const t = useTranslations(lang);
const imgSrc = resolveImageUrl(post.coverImage as CoverImageLike, {
  width: 1400,
  height: 787,
});
const date = formatPostDate(post.publishedAt, lang);
const mins = post.body ? readingTime(post.body) : null;
const categoryName =
  (post.category?.name as Record<string, string> | undefined)?.[lang] ??
  (post.category?.name as Record<string, string> | undefined)?.es ??
  "";
const authorNames = post.authors?.map((a) => a.name).join(", ") ?? "";
---

<header
  class="mx-auto max-w-[var(--container-text,720px)] px-[var(--gutter)] pt-[var(--space-8)] text-center"
>
  {
    categoryName && (
      <Badge tone="gold" class="mb-4">
        {categoryName}
      </Badge>
    )
  }
  <h1
    class="text-olive mb-5 font-serif leading-tight font-semibold"
    style="font-size: clamp(2.4rem, 4.5vw, 3.6rem);"
  >
    {post.title}
  </h1>
  {
    post.excerpt && (
      <p class="text-lead text-olive-soft mx-auto mb-6 max-w-[640px] leading-normal">
        {post.excerpt}
      </p>
    )
  }
  <p class="text-caption text-olive-faint">
    {
      authorNames && (
        <span>
          {t("blog.by")} {authorNames} ·{" "}
        </span>
      )
    }
    {date}
    {
      mins && (
        <span>
          {" "}
          · {mins} {t("blog.minutes")}
        </span>
      )
    }
  </p>
</header>

{
  imgSrc && (
    <div class="mx-auto mt-8 max-w-[var(--container)] px-[var(--gutter)]">
      <img
        src={imgSrc}
        alt={post.title}
        loading="eager"
        class="rounded-radius-xl aspect-video w-full object-cover shadow-md"
      />
    </div>
  )
}
