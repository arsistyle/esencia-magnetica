---
// src/components/blog/PostHero.astro
import type { Locale } from "@/types/index";
import { useTranslations } from "@/i18n";
import {
  resolveImageUrl,
  buildSrcSet,
  type CoverImageLike,
} from "@/lib/sanity";
import Badge from "@/components/ui/Badge.astro";
import { formatPostDate, readingTime } from "@/lib/blog/postViewModel";

interface Props {
  post: {
    title: string;
    slug?: { current: string };
    publishedAt: string;
    excerpt?: string;
    coverImage?: unknown;
    category?: {
      name: Record<string, string>;
      slug?: { es?: string; en?: string };
    };
    authors?: Array<{ name: string }>;
    body?: unknown[];
    tags?: string[];
  };
  lang: Locale;
}

const { post, lang } = Astro.props;
const t = useTranslations(lang);
const blogPath = lang === "en" ? "/en/blog" : "/blog";
const coverImage = post.coverImage as CoverImageLike;
const imgSrc = resolveImageUrl(coverImage, {
  width: 1400,
  format: "webp",
  quality: 85,
});
const imgSrcSet = buildSrcSet(coverImage, [800, 1200, 1400], {
  format: "webp",
  quality: 85,
});
const date = formatPostDate(post.publishedAt, lang);
const mins = post.body ? readingTime(post.body) : null;
const categoryName =
  (post.category?.name as Record<string, string> | undefined)?.[lang] ??
  (post.category?.name as Record<string, string> | undefined)?.es ??
  "";
const categorySlug = post.category?.slug?.es ?? "";
const authorNames = post.authors?.map((a) => a.name).join(", ") ?? "";
---

<header class="mx-auto max-w-[var(--container)] px-[var(--gutter)] pb-5">
  {
    categoryName && (
      <a
        href={`${blogPath}?categoria=${encodeURIComponent(categorySlug)}`}
        class="mb-4 inline-block"
      >
        <Badge tone="gold">{categoryName}</Badge>
      </a>
    )
  }
  <h1
    class="text-olive mb-5 font-serif leading-tight font-semibold"
    style="font-size: clamp(2.4rem, 4.5vw, 3.6rem);"
  >
    {post.title}
  </h1>
  {
    post.excerpt && (
      <p class="text-lead text-olive-soft mb-6 max-w-[640px] leading-normal">
        {post.excerpt}
      </p>
    )
  }
  <p class="text-caption text-olive-faint">
    {
      authorNames && (
        <span>
          {t("blog.by")} {authorNames} ·{" "}
        </span>
      )
    }
    {date}
    {
      mins && (
        <span>
          {" "}
          · {mins} {t("blog.minutes")}
        </span>
      )
    }
  </p>
  {
    post.tags && post.tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2">
        {post.tags.map((tag) => (
          <a
            href={`${blogPath}?q=${encodeURIComponent(tag)}`}
            class="border-line-strong text-olive-soft hover:border-gold hover:text-olive rounded-pill border px-3 py-1 font-sans text-[12px] transition-colors"
          >
            {tag}
          </a>
        ))}
      </div>
    )
  }
</header>

{
  imgSrc && (
    <div class="mx-auto mt-8 max-w-[var(--container)] px-[var(--gutter)]">
      <img
        src={imgSrc}
        srcset={imgSrcSet || undefined}
        sizes="(min-width: 1280px) 1280px, 100vw"
        alt={coverImage?.alt ?? post.title}
        width="1400"
        height="787"
        loading="eager"
        transition:name={`post-image-${post.slug?.current ?? ""}`}
        class="aspect-video w-full rounded-xl object-cover shadow-md"
      />
    </div>
  )
}
