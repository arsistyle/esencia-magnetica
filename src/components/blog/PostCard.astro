---
// src/components/blog/PostCard.astro
import type { Locale } from "@/types/index";
import { useTranslations } from "@/i18n";
import { resolveImageUrl, type CoverImageLike } from "@/lib/sanity";
import { formatPostDate } from "@/lib/blog/postViewModel";

interface Props {
  post: {
    _id: string;
    title: string;
    slug: { current: string };
    excerpt?: string;
    publishedAt: string;
    coverImage?: unknown;
    readTime?: number;
    category?: { name: Record<string, string>; slug: { current: string } };
  };
  lang: Locale;
}

const { post, lang } = Astro.props;
const t = useTranslations(lang);
const href =
  lang === "es"
    ? `/blog/${post.slug.current}`
    : `/en/blog/${post.slug.current}`;
const imgSrc = resolveImageUrl(post.coverImage as CoverImageLike, {
  width: 600,
  height: 338,
});
const date = formatPostDate(post.publishedAt, lang);
const mins = Math.max(1, post.readTime ?? 1);
const categoryName =
  (post.category?.name as Record<string, string> | undefined)?.[lang] ??
  (post.category?.name as Record<string, string> | undefined)?.es ??
  "";
---

<a
  href={href}
  class="group border-line bg-cream-card flex flex-col overflow-hidden rounded-lg border shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md"
>
  {
    imgSrc ? (
      <img
        src={imgSrc}
        alt={post.title}
        loading="lazy"
        class="rounded-t-radius-lg aspect-video w-full object-cover"
      />
    ) : (
      <div class="bg-lavender rounded-t-radius-lg aspect-video w-full" />
    )
  }
  <div class="flex flex-col gap-3 p-5">
    {
      categoryName && (
        <span class="text-overline text-gold font-sans font-bold tracking-wider uppercase">
          {categoryName}
        </span>
      )
    }
    <h2 class="text-h4 text-olive font-serif leading-tight font-semibold">
      {post.title}
    </h2>
    {
      post.excerpt && (
        <p class="text-small text-olive-soft line-clamp-3 leading-normal">
          {post.excerpt}
        </p>
      )
    }
    <p class="text-caption text-olive-faint mt-auto">
      {date} · {mins}
      {t("blog.minutes")}
    </p>
  </div>
</a>
