---
// src/components/blog/PostCard.astro
import type { Locale } from "@/types/index";
import { useTranslations } from "@/i18n";
import { urlFor } from "@/lib/sanity";
import Badge from "@/components/ui/Badge.astro";
import { ArrowRight } from "@lucide/astro";
import { formatPostDate } from "@/lib/blog/postViewModel";

interface Props {
  post: {
    _id: string;
    title: string;
    slug: { current: string };
    excerpt?: string;
    publishedAt: string;
    coverImage?: unknown;
    category?: { name: Record<string, string>; slug: { current: string } };
  };
  lang: Locale;
}

const { post, lang } = Astro.props;
const t = useTranslations(lang);
const href =
  lang === "es"
    ? `/blog/${post.slug.current}`
    : `/en/blog/${post.slug.current}`;
const imgSrc = post.coverImage
  ? urlFor(post.coverImage as Parameters<typeof urlFor>[0])
      .width(600)
      .height(600)
      .url()
  : null;
const date = formatPostDate(post.publishedAt, lang);
const categoryName =
  (post.category?.name as Record<string, string> | undefined)?.[lang] ??
  (post.category?.name as Record<string, string> | undefined)?.es ??
  "";
---

<article class="flex flex-col gap-4">
  <a href={href} class="block overflow-hidden rounded-md">
    {
      imgSrc ? (
        <img
          src={imgSrc}
          alt={post.title}
          loading="lazy"
          class="aspect-square w-full object-cover transition-transform duration-300 hover:scale-105"
        />
      ) : (
        <div class="bg-lavender aspect-square w-full" />
      )
    }
  </a>
  <div class="flex flex-col gap-2">
    {
      categoryName && (
        <Badge tone="neutral" size="sm">
          {categoryName}
        </Badge>
      )
    }
    <h2 class="text-h4 text-olive font-serif leading-tight font-semibold">
      <a href={href} class="hover:text-gold transition-colors">{post.title}</a>
    </h2>
    <p class="text-caption text-olive-faint font-sans">{date}</p>
    {
      post.excerpt && (
        <p class="text-small text-olive-soft line-clamp-3 leading-normal">
          {post.excerpt}
        </p>
      )
    }
    <a
      href={href}
      class="text-small text-gold hover:text-gold-deep flex items-center gap-1 font-sans font-bold transition-colors"
    >
      {t("blog.read")}
      <ArrowRight class="h-4 w-4" />
    </a>
  </div>
</article>
