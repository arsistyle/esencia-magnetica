---
// src/components/blog/PostGrid.astro
import type { Locale } from "@/types/index";
import { useTranslations } from "@/i18n";
import PostCard from "./PostCard.astro";

interface Props {
  posts: Parameters<typeof PostCard>[0]["post"][];
  q: string;
  lang: Locale;
}

const { posts, q, lang } = Astro.props;
const t = useTranslations(lang);
const emptyMsg = q ? t("blog.empty.search").replace("{q}", q) : t("blog.empty");
---

{
  posts.length === 0 ? (
    <div class="py-20 text-center">
      <p class="text-lead text-olive-soft">{emptyMsg}</p>
    </div>
  ) : (
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => (
        <PostCard post={post} lang={lang} />
      ))}
    </div>
  )
}
