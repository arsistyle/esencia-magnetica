---
// src/components/home/MarqueeRow.astro
// Independent marquee row. Pass direction and items (images with gradient fallback).
// Multiple instances on the same page each run their own animation loop.
import type { MarqueeItem } from "@/lib/home/marqueeItems";

interface Props {
  direction?: "left" | "right";
  /** Row height, any CSS length. Default: "300px" */
  height?: string;
  items: MarqueeItem[];
}

const { direction = "left", height = "300px", items } = Astro.props;
// ponytail: triple content — seamless wrap at any viewport width
const tiles = [...items, ...items, ...items];
---

<div
  class="w-full overflow-hidden"
  style={`height: ${height}`}
  data-marquee
  data-direction={direction}
  data-set-size={items.length}
  aria-hidden="true"
>
  <div class="mq-track" style="will-change: transform">
    {
      tiles.map(({ bg, src, alt, aspectRatio }) => (
        <div
          class="mq-tile"
          style={`background: ${bg}${!src ? `; aspect-ratio: ${aspectRatio ?? "3/4"}` : ""}`}
        >
          {src && (
            <img
              src={src}
              alt={alt ?? ""}
              loading="lazy"
              class="block h-full w-auto"
            />
          )}
        </div>
      ))
    }
  </div>
</div>

<style>
  .mq-track {
    display: flex;
    width: max-content;
    height: 100%;
  }
  .mq-tile {
    flex: none;
    height: 100%;
  }
</style>

<script>
  function initMarquees() {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    document
      .querySelectorAll<HTMLElement>("[data-marquee]:not([data-mq-init])")
      .forEach((container) => {
        container.dataset.mqInit = "1";

        const direction = container.dataset.direction as "left" | "right";
        const setSize = parseInt(container.dataset.setSize ?? "8", 10);
        const track = container.querySelector<HTMLElement>(".mq-track");
        if (!track) return;

        const el: HTMLElement = track;

        const BASE_SPEED = 0.6;
        const SCROLL_FACTOR = 0.08;
        const FRICTION = 0.92;

        const wrap = (x: number, sw: number): number =>
          ((((x + sw) % sw) + sw) % sw) - sw;

        const measureSet = (): number => {
          let w = 0;
          for (let i = 0; i < setSize; i++) {
            w += (el.children[i] as HTMLElement).getBoundingClientRect().width;
          }
          return w || 1;
        };

        let sw = measureSet();
        let x = -sw;
        let scrollVel = 0;
        let lastY = window.scrollY;
        let running = true;

        const ac = new AbortController();

        window.addEventListener(
          "scroll",
          () => {
            scrollVel += Math.abs(window.scrollY - lastY);
            lastY = window.scrollY;
          },
          { passive: true, signal: ac.signal },
        );

        document.addEventListener(
          "astro:before-swap",
          () => {
            running = false;
            ac.abort();
          },
          { once: true },
        );

        const ro = new ResizeObserver(() => {
          sw = measureSet();
          x = wrap(x, sw);
        });
        ro.observe(container);

        function tick() {
          if (!running) return;
          scrollVel *= FRICTION;
          const speed = BASE_SPEED + scrollVel * SCROLL_FACTOR;
          x = direction === "left" ? wrap(x - speed, sw) : wrap(x + speed, sw);
          el.style.transform = `translateX(${x.toFixed(2)}px)`;
          requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      });
  }

  document.addEventListener("astro:page-load", initMarquees);
  initMarquees();
</script>
