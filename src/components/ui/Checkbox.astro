---
import { cn } from "@/lib/utils";

interface Props {
  label?: string;
  name?: string;
  value?: string;
  checked?: boolean;
  required?: boolean;
  class?: string;
}

const {
  label,
  name,
  value,
  checked = false,
  required = false,
  class: className,
} = Astro.props;
---

<label
  class={cn(
    "inline-flex items-center gap-2 cursor-pointer font-sans text-body text-olive",
    className,
  )}
>
  <input
    type="checkbox"
    name={name}
    value={value}
    checked={checked}
    required={required}
    class="accent-gold h-4 w-4 cursor-pointer rounded-sm"
  />
  {label && <span>{label}</span>}
</label>
