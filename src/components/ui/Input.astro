---
import { cn } from "@/lib/utils";

interface Props {
  label?: string;
  hint?: string;
  id?: string;
  type?: string;
  required?: boolean;
  class?: string;
  [key: string]: unknown;
}

const {
  label,
  hint,
  id,
  type = "text",
  required = false,
  class: className,
  ...rest
} = Astro.props;

const inputId = id ?? label?.toLowerCase().replace(/\s+/g, "-");

const inputClasses = cn(
  "w-full bg-cream-card border border-line-strong rounded-md px-3 py-3 text-body font-sans text-olive focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold/45 focus-visible:border-gold",
  className,
);

// Astro type compatibility: cast through unknown to satisfy HTML input type attribute
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const inputType = type as any;
---

<div class="flex flex-col gap-1">
  {
    label && (
      <label
        for={inputId}
        class="text-overline text-olive-soft font-sans font-bold tracking-wide uppercase"
      >
        {label}
        {required && (
          <span class="text-danger ml-1" aria-hidden="true">
            *
          </span>
        )}
      </label>
    )
  }
  <input
    id={inputId}
    type={inputType}
    required={required}
    class={inputClasses}
    {...rest}
  />
  {hint && <p class="text-caption text-olive-faint mt-1 font-sans">{hint}</p>}
</div>
