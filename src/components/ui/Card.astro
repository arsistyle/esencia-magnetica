---
import { cva, type VariantProps } from "class-variance-authority";
import { cn } from "@/lib/utils";

const card = cva(
  "bg-cream-card border border-line rounded-lg overflow-hidden",
  {
    variants: {
      hover: {
        true: "hover:-translate-y-1 hover:shadow-md transition-all duration-base ease-soft",
        false: "",
      },
      padding: {
        none: "p-0",
        sm: "p-3",
        md: "p-5",
        lg: "p-8",
      },
    },
    defaultVariants: { hover: true, padding: "md" },
  },
);

type CardVariants = VariantProps<typeof card>;

interface Props extends CardVariants {
  class?: string;
}

const { hover = true, padding = "md", class: className } = Astro.props;
const classes = cn(card({ hover, padding }), className);
---

<div class={classes}>
  <slot />
</div>
