---
// src/components/brand/BrandFilosofia.astro
import Badge from "@/components/ui/Badge.astro";

interface Props {
  chip?: string;
  title?: string;
  description?: string;
  pillars?: Array<{ title?: string; desc?: string }>;
}

const { chip, title, description, pillars } = Astro.props;

const activePillars = (pillars ?? [])
  .filter((p) => p.title || p.desc)
  .map((p, i) => ({
    num: String(i + 1).padStart(2, "0"),
    title: p.title,
    desc: p.desc,
  }));
---

<section
  class="mx-auto max-w-[var(--container)] px-[var(--gutter)] py-[var(--space-9)]"
>
  <div class="mb-[var(--space-7)] text-center">
    {chip && <Badge tone="rose">{chip}</Badge>}
    {
      title && (
        <h2 class="text-olive text-h2 mt-3 mb-2 font-serif leading-tight font-semibold">
          {title}
        </h2>
      )
    }
    {
      description && (
        <p class="text-olive-soft text-lead mx-auto max-w-[560px]">
          {description}
        </p>
      )
    }
  </div>

  {
    activePillars.length > 0 && (
      <div class="grid grid-cols-1 gap-[var(--space-7)] sm:grid-cols-3">
        {activePillars.map((p) => (
          <div class="text-center">
            <span
              class="text-gold text-h1 font-serif leading-none italic"
              aria-hidden="true"
            >
              {p.num}
            </span>
            {p.title && (
              <h3 class="text-olive mt-3 mb-2 font-serif text-2xl font-semibold">
                {p.title}
              </h3>
            )}
            {p.desc && (
              <p class="text-olive-soft text-body leading-normal">{p.desc}</p>
            )}
          </div>
        ))}
      </div>
    )
  }
</section>
