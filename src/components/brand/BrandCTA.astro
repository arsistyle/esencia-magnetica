---
// src/components/brand/BrandCTA.astro
import type { Locale } from "@/types/index";
import Button from "@/components/ui/Button.astro";

interface Props {
  lang: Locale;
  title?: string;
  buttonText?: string;
  buttonUrl?: string;
}

const { lang, title, buttonText, buttonUrl } = Astro.props;

const sectionButtonUrl = buttonUrl ?? (lang === "en" ? "/en/blog" : "/blog");
---

<section
  class="bg-rose-nude px-[var(--gutter)] py-[var(--space-9)] text-center"
>
  {
    title && (
      <h2
        class="text-olive text-h2 mx-auto mb-[var(--space-5)] font-serif leading-tight font-semibold"
        style="max-width: 600px"
      >
        {title}
      </h2>
    )
  }
  {
    buttonText && (
      <Button variant="primary" size="lg" href={sectionButtonUrl}>
        {buttonText}
      </Button>
    )
  }
</section>
