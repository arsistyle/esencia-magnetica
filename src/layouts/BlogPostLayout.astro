---
// src/layouts/BlogPostLayout.astro
import BaseLayout from "./BaseLayout.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import PostHero from "@/components/blog/PostHero.astro";
import PostBody from "@/components/blog/PostBody.astro";
import RelatedProducts from "@/components/blog/RelatedProducts.astro";
import FacebookComments from "@/components/blog/FacebookComments.astro";
import { resolveImageUrl, type CoverImageLike } from "@/lib/sanity";
import type { Locale } from "@/types/index";
import { useTranslations } from "@/i18n";
import { toHTML } from "@portabletext/to-html";

type PortableTextBody = Parameters<typeof toHTML>[0];

interface Product {
  _id: string;
  name?: string;
  image?: unknown;
  affiliateUrl?: string;
  store?: string;
}

interface Props {
  post: {
    title: string;
    slug?: { current: string };
    excerpt?: string;
    publishedAt: string;
    coverImage?: CoverImageLike;
    body?: unknown[];
    category?: { name: Record<string, string> };
    authors?: Array<{ name: string }>;
    seo?: {
      metaTitle?: string;
      metaDescription?: string;
      ogImage?: CoverImageLike;
    };
  };
  lang: Locale;
  esUrl: string;
  enUrl: string;
}

const { post, lang, esUrl, enUrl } = Astro.props;
const t = useTranslations(lang);

const ogImage =
  resolveImageUrl(post.seo?.ogImage, { width: 1200 }) ??
  resolveImageUrl(post.coverImage, { width: 1200 }) ??
  undefined;

const siteBase = Astro.site?.toString().replace(/\/$/, "") ?? "";
const canonicalPath = lang === "es" ? esUrl : enUrl;
const canonical = `${siteBase}${canonicalPath}`;

const categoryName =
  (post.category?.name as Record<string, string> | undefined)?.[lang] ??
  (post.category?.name as Record<string, string> | undefined)?.es;

const postBody = (post.body ?? []) as PortableTextBody;

const products = (post.body ?? [])
  .filter(
    (b): b is Record<string, unknown> =>
      typeof b === "object" &&
      b !== null &&
      (b as Record<string, unknown>)._type === "productList",
  )
  .flatMap((b) => (b.products as Product[] | undefined) ?? []);
---

<BaseLayout
  title={post.seo?.metaTitle ?? post.title}
  description={post.seo?.metaDescription ?? post.excerpt}
  ogImage={ogImage}
  lang={lang}
  canonical={canonical}
  alternates={{ es: esUrl, en: enUrl }}
  article={{
    publishedTime: post.publishedAt,
    authors: post.authors?.map((a) => a.name),
    section: categoryName,
  }}
>
  <div
    class="mx-auto max-w-[var(--container)] px-[var(--gutter)] pt-[var(--space-8)] pb-2.5"
  >
    <Breadcrumb
      items={[
        { label: t("nav.home"), href: lang === "en" ? "/en" : "/" },
        { label: t("nav.blog"), href: lang === "en" ? "/en/blog" : "/blog" },
        { label: post.title },
      ]}
      lang={lang}
    />
  </div>
  <PostHero post={post} lang={lang} />
  <div
    class="mx-auto max-w-[var(--container)] [padding:var(--space-8)_var(--gutter)_var(--space-9)]"
  >
    <div class="mx-auto max-w-[720px]">
      <PostBody body={postBody} lang={lang} />
    </div>
  </div>
  <RelatedProducts products={products} lang={lang} />
  <FacebookComments url={canonical} lang={lang} />
</BaseLayout>
