---
// src/layouts/BaseLayout.astro
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";
import { SEO } from "astro-seo";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import Analytics from "@/components/Analytics.astro";
import CookieBanner from "@/components/CookieBanner.astro";
import { useTranslations, getLocalizedUrl } from "@/i18n";
import type { Locale } from "@/types/index";
import { sanityClient } from "sanity:client";
import { siteNavQuery } from "@/lib/queries";

interface Props {
  title: string;
  description?: string;
  lang?: Locale;
  ogImage?: string;
  canonical?: string;
  alternates?: { es: string; en: string };
  jsonLd?: string;
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    expirationTime?: string;
    authors?: string[];
    section?: string;
    tags?: string[];
  };
}

const {
  title,
  description = "Esencia Magnética — moda y estilo para mujeres 40+",
  lang = "es",
  ogImage,
  canonical,
  alternates,
  jsonLd,
  article,
} = Astro.props;

const t = useTranslations(lang);
const currentPath = Astro.url.pathname;

const siteNav = await sanityClient.fetch(siteNavQuery, {
  brandId: `brand-${lang}`,
  locale: lang,
});

const esPath =
  alternates?.es ??
  (lang === "es" ? currentPath : getLocalizedUrl("es", currentPath));
const enPath =
  alternates?.en ??
  (lang === "en" ? currentPath : getLocalizedUrl("en", currentPath));

const siteBase = Astro.site?.toString().replace(/\/$/, "") ?? "";
const canonicalUrl = canonical ?? `${siteBase}${currentPath}`;
const gtmId = import.meta.env.PUBLIC_GTM_ID as string | undefined;
---

<!doctype html>
<html lang={lang}>
  <head>
    <Analytics />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter />
    <SEO
      title={title}
      titleTemplate="%s — Esencia Magnética"
      description={description}
      canonical={canonicalUrl}
      openGraph={{
        basic: {
          title: `${title} — Esencia Magnética`,
          type: article ? "article" : "website",
          image: ogImage ?? "",
          url: canonicalUrl,
        },
        ...(article && { article }),
      }}
      languageAlternates={[
        { hrefLang: "es", href: `${siteBase}${esPath}` },
        { hrefLang: "en", href: `${siteBase}${enPath}` },
        { hrefLang: "x-default", href: `${siteBase}${esPath}` },
      ]}
    />
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
  </head>
  <body>
    {
      gtmId && (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
            height="0"
            width="0"
            style="display:none;visibility:hidden"
            title="Google Tag Manager"
          />
        </noscript>
      )
    }
    <a
      href="#main-content"
      class="focus:bg-gold sr-only focus:not-sr-only focus:absolute focus:top-0 focus:left-0 focus:z-[9999] focus:rounded-br-md focus:px-4 focus:py-2 focus:text-white"
    >
      {t("common.skip")}
    </a>
    <Navbar
      lang={lang}
      currentPath={currentPath}
      logoUrl={siteNav?.logo}
      headerNavItems={siteNav?.headerMenu}
      mobileNavItems={siteNav?.mobileMenu}
    />
    <main id="main-content">
      <slot />
    </main>
    <Footer lang={lang} footerNavItems={siteNav?.footerMenu} />
    <CookieBanner lang={lang} />
  </body>
</html>
