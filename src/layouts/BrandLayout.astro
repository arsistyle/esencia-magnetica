---
// src/layouts/BrandLayout.astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import BrandHero from "@/components/brand/BrandHero.astro";
import BrandHistoria from "@/components/brand/BrandHistoria.astro";
import BrandFilosofia from "@/components/brand/BrandFilosofia.astro";
import BrandMisionVision from "@/components/brand/BrandMisionVision.astro";
import BrandQueEncontrar from "@/components/brand/BrandQueEncontrar.astro";
import BrandCTA from "@/components/brand/BrandCTA.astro";
import { useTranslations } from "@/i18n";
import { ptToHtml } from "@/lib/brand/brandViewModel";
import { safeUrlFor } from "@/lib/sanity";
import { buildBrandJsonLd } from "@/lib/seo";
import type { Brand, Page } from "@/types/sanity.types";
import type { Locale } from "@/types/index";

interface Props {
  brand: Brand | null;
  page: Page | null;
  lang: Locale;
}

const { brand, page, lang } = Astro.props;
const t = useTranslations(lang);

// SEO
const seoTitle = page?.seo?.metaTitle ?? t("nav.brand");
const seoDescription =
  page?.seo?.metaDescription ??
  (brand ? `${brand.tagline ?? ""} ${brand.name ?? ""}`.trim() : undefined);
const heroUrl = brand?.heroPhoto
  ? (safeUrlFor(brand.heroPhoto)?.width(800).height(1000).url() ?? undefined)
  : undefined;

// Flatten aboutContent for readability
const ac = page?.aboutContent;

const intro = ac?.intro;

const historyEnabled = ac?.history?.enabled ?? false;
const historyTag = ac?.history?.tag;
const historyTitle = ac?.history?.title;
const historyPhoto = ac?.history?.photo;
const historyBodyHtml = ptToHtml(ac?.history?.body);

const philosophyEnabled = ac?.philosophy?.enabled ?? false;
const philosophyChip = ac?.philosophy?.chip;
const philosophyTitle = ac?.philosophy?.title;
const philosophyDesc = ac?.philosophy?.description;
const philosophyPillars = ac?.philosophy?.pillars;

const whatYouFindEnabled = ac?.whatYouFind?.enabled ?? false;
const whatYouFindChip = ac?.whatYouFind?.chip;
const whatYouFindTitle = ac?.whatYouFind?.title;
const whatYouFindCards = ac?.whatYouFind?.cards;

const blogCtaEnabled = ac?.blogCta?.enabled ?? false;
const blogCtaTitle = ac?.blogCta?.title;
const blogCtaButtonText = ac?.blogCta?.buttonText;
const blogCtaButtonUrl = ac?.blogCta?.buttonUrl;

// JSON-LD: Person + Organization
const personName = brand?.name ?? "";
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const brandPath = lang === "en" ? "/en/brand" : "/marca";

// ponytail: brand.logo is a raw Sanity image — use safeUrlFor directly
const logoUrl = brand?.logo
  ? (safeUrlFor(brand.logo)?.width(400).format("webp").url() ?? undefined)
  : undefined;
const socialUrls = (brand?.socialLinks ?? [])
  .map((l: { platform?: string; url?: string }) => l.url ?? "")
  .filter(Boolean);

const jsonLd = buildBrandJsonLd({
  personName,
  siteUrl,
  brandUrl: `${siteUrl}${brandPath}`,
  heroUrl: heroUrl ?? undefined,
  logoUrl,
  socialUrls,
});

// hreflang alternates
const esPath = lang === "es" ? brandPath : "/marca";
const enPath = lang === "en" ? brandPath : "/en/brand";
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  lang={lang}
  ogImage={heroUrl}
  alternates={{ es: esPath, en: enPath }}
  jsonLd={jsonLd}
>
  <BrandHero brand={brand} intro={intro} />
  {
    historyEnabled && (
      <BrandHistoria
        photo={historyPhoto}
        bodyHtml={historyBodyHtml}
        tag={historyTag}
        title={historyTitle}
      />
    )
  }
  {
    philosophyEnabled && (
      <BrandFilosofia
        chip={philosophyChip}
        title={philosophyTitle}
        description={philosophyDesc}
        pillars={philosophyPillars}
      />
    )
  }
  <BrandMisionVision mission={brand?.mission} vision={brand?.vision} t={t} />
  {
    whatYouFindEnabled && (
      <BrandQueEncontrar
        chip={whatYouFindChip}
        title={whatYouFindTitle}
        cards={whatYouFindCards}
        t={t}
        lang={lang}
      />
    )
  }
  {
    blogCtaEnabled && (
      <BrandCTA
        title={blogCtaTitle}
        buttonText={blogCtaButtonText}
        buttonUrl={blogCtaButtonUrl}
        lang={lang}
      />
    )
  }
</BaseLayout>
